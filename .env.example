# ── Model providers (leave empty + JAI_MOCK=1 for fully keyless local dev) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Gateway ──
LITELLM_MASTER_KEY=sk-jai-master-dev
LITELLM_BASE_URL=http://localhost:4000

# ── Mock mode: 1 = every model call returns a deterministic mock via the gateway ──
JAI_MOCK=1

# ── Postgres (single instance; each part owns its schema namespace) ──
JAI_POSTGRES_PORT=5433
POSTGRES_URL=postgresql://jai:jai@localhost:5433/jai

# ── Observability (optional; console exporter used when unset) ──
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Gateway config file: config.yaml (real providers) or config.mock.yaml (keyless) ──
LITELLM_CONFIG_FILE=config.mock.yaml
